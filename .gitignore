# Whitelist approach: pi mutates agent/ aggressively (npm cache, sessions,
# MCP caches, etc). Ignore everything, explicitly allow only files we want
# version-controlled. Prevents accidental `git add .` commits of mutable state.

# ignore everything
*

# exceptions
!.gitignore
!README.md
!agent/
!agent/AGENTS.md
!agent/extensions/
!agent/extensions/destructive-guard.ts
!agent/extensions/mmx-search.ts
!agent/keybindings.json
!agent/mcp.json
!agent/models.json
!agent/settings.json
